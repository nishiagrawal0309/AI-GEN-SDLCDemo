{
  "name": "sitemap-redirect-checker",
  "version": "1.0.0",
  "description": "Parse a sitemap XML, detect HTTP redirects, and export a CSV report.",
  "type": "module",
  "main": "sitemap_redirect_checker.js",
  "scripts": {
    "start": "node scripts/sitemap_redirect_checker.js",
    "generate:redirect-report": "node scripts/sitemap_redirect_checker.js docs/requirements/SiteMapGeneratorReq/sample_sitemap.xml",
    "generate:redirect-report:limited": "node scripts/sitemap_redirect_checker.js docs/requirements/SiteMapGeneratorReq/sample_sitemap.xml web/pages/redirect_report.csv web/pages/redirect_report_resolved.xml --max-urls=10"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "fast-xml-parser": "^4.4.0",
    "tinyld": "^1.3.4"
  }
}
